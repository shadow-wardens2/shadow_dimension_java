<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefWidth="250.0" styleClass="panel-card" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Marketplace.TypeCardController">
   <children>
      <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" spacing="5.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label fx:id="typeName" styleClass="bento-title" text="Type Name" style="-fx-font-size: 22px; -fx-text-fill: #ba9eff;" />
                  <Label fx:id="typeId" style="-fx-text-fill: #5a5070; -fx-font-size: 11px;" text="ID: 1" />
               </children>
               <padding>
                  <Insets bottom="10.0" top="10.0" />
               </padding>
            </VBox>
            <HBox spacing="10.0">
               <children>
                  <Button fx:id="btnEdit" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="edit-button" text="Edit" HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnDelete" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="delete-button" text="Delete" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
