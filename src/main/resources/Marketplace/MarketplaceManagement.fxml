<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.MarketplaceManagementController">
   <children>
      <VBox alignment="CENTER" spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" spacing="5">
                <Label styleClass="headline" text="Marketplace Dashboard" />
                <Label styleClass="subheadline" text="Select a module to manage your marketplace data" />
            </VBox>
            <HBox alignment="CENTER" spacing="25.0">
               <children>
                  <Button fx:id="btnProducts" mnemonicParsing="false" onAction="#openProducts" prefHeight="70.0" prefWidth="180.0" styleClass="glow-button" text="Manage Products" />
                  <Button fx:id="btnCategories" mnemonicParsing="false" onAction="#openCategories" prefHeight="70.0" prefWidth="180.0" styleClass="glow-button" text="Manage Categories" />
                  <Button fx:id="btnTypes" mnemonicParsing="false" onAction="#openTypes" prefHeight="70.0" prefWidth="180.0" styleClass="glow-button" text="Manage Types" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
