<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane fx:id="rootNode" prefHeight="900.0" prefWidth="1440.0" styleClass="root" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Marketplace.Front.CartViewController">
    <VBox spacing="30.0" alignment="TOP_CENTER" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="200.0" AnchorPane.topAnchor="50.0">
        <HBox alignment="CENTER_LEFT">
            <Button text="&lt; Back to Bazaar" onAction="#handleBack" styleClass="secondary-button" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Your Artifact Cart" styleClass="headline" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>
        
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
            <VBox fx:id="cartItemsContainer" spacing="15.0" />
        </ScrollPane>
        
        <HBox alignment="CENTER_RIGHT" spacing="30.0" style="-fx-background-color: #1c1922; -fx-padding: 20; -fx-background-radius: 12;">
            <Label fx:id="lbTotal" text="Total: 0.00 TND" styleClass="headline-md" style="-fx-text-fill: #d3bbff;" />
            <Button text="Proceed to Checkout" onAction="#handleCheckout" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 12 30; -fx-background-radius: 8; -fx-cursor: hand;" />
        </HBox>
    </VBox>
</AnchorPane>
