<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" styleClass="artifact-card" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Marketplace.Front.FrontProductCardController" prefWidth="300.0" minWidth="300.0" minHeight="450.0" style="-fx-background-color: #24202b; -fx-background-radius: 24; -fx-padding: 20;">
    
    <StackPane prefHeight="220.0" prefWidth="260.0" style="-fx-background-color: #1c1922; -fx-background-radius: 16;">
        <Rectangle fx:id="imagePlaceholder" arcHeight="32" arcWidth="32" fill="#1c1922" height="220.0" width="260.0" />
        <ImageView fx:id="ivProduct" fitHeight="220.0" fitWidth="260.0" pickOnBounds="true" preserveRatio="true" />
    </StackPane>

    <VBox spacing="8.0" VBox.vgrow="ALWAYS">
        <Label fx:id="lbCategory" styleClass="label-sigil" text="LEGENDARY TIER" opacity="0.6" />
        <Label fx:id="lbName" styleClass="title-lg" text="Artifact Name" wrapText="true" />
        <Label fx:id="lbDescription" styleClass="body-md" text="Short description of the artifact..." wrapText="true" opacity="0.5" prefHeight="60.0" alignment="TOP_LEFT" />
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="lbPrice" styleClass="title-lg" text="0.00 TND" style="-fx-text-fill: #d3bbff;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button mnemonicParsing="false" onAction="#handleAddToCart" text="Cart +" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-padding: 8 15;" />
        <VBox alignment="CENTER_RIGHT">
            <Label styleClass="label-sigil" text="STOCK" opacity="0.4" style="-fx-font-size: 10px;" />
            <Label fx:id="lbStock" styleClass="label-sigil" text="12" />
        </VBox>
    </HBox>
</VBox>
