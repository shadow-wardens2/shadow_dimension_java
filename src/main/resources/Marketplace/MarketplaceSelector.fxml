<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="30.0" stylesheets="@../style.css" style="-fx-background-color: #050507;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Marketplace.MarketplaceSelectorController">
    <Label styleClass="headline" text="Marketplace Protocol" />
    <Label styleClass="subheadline" text="Select the dimensional module you wish to configure" />
    <Button mnemonicParsing="false" onAction="#goBack" styleClass="secondary-button" text="&lt; Back to Home" />
    <HBox alignment="CENTER" spacing="25.0" style="-fx-padding: 20 0 0 0;">
        <Button mnemonicParsing="false" onAction="#handleProducts" prefHeight="70.0" prefWidth="180.0" styleClass="glow-button" text="Manage Products" />
        <Button mnemonicParsing="false" onAction="#handleCategories" prefHeight="70.0" prefWidth="180.0" styleClass="secondary-button" text="Manage Categories" />
        <Button mnemonicParsing="false" onAction="#handleTypes" prefHeight="70.0" prefWidth="180.0" styleClass="secondary-button" text="Manage Types" />
    </HBox>
    <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 10 0 0 0;">
        <Button mnemonicParsing="false" onAction="#handleDownloadReport" styleClass="secondary-button" text="Download Marketplace Report (PDF)" />
        <Button mnemonicParsing="false" onAction="#handleStatistics" styleClass="secondary-button" text="View Statistics" />
    </HBox>
</VBox>
