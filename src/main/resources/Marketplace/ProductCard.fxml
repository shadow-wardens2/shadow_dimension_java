<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="320.0" prefWidth="240.0" styleClass="panel-card" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Marketplace.ProductCardController">
   <children>
      <VBox alignment="TOP_CENTER" spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <AnchorPane prefHeight="140.0" prefWidth="200.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 8;">
               <children>
                  <ImageView fx:id="productImage" fitHeight="130.0" fitWidth="180.0" layoutX="10.0" layoutY="5.0" pickOnBounds="true" preserveRatio="true" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="5.0" />
               </children>
            </AnchorPane>
            <Label fx:id="productName" styleClass="bento-title" text="Product Name">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            <Label fx:id="productDescription" styleClass="subheadline" text="Short description goes here..." wrapText="true" />
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label styleClass="form-label" text="Price:" />
                  <Label fx:id="productPrice" style="-fx-text-fill: #8b5cf6;" text="\$0.00">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <Pane HBox.hgrow="ALWAYS" />
                  <Label styleClass="form-label" text="Stock:" />
                  <Label fx:id="productStock" style="-fx-text-fill: #adaaae;" text="0" />
               </children>
            </HBox>
            <Pane VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleEdit" prefWidth="90.0" styleClass="edit-button" text="Edit" />
                  <Button mnemonicParsing="false" onAction="#handleDelete" prefWidth="90.0" styleClass="delete-button" text="Delete" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</AnchorPane>
