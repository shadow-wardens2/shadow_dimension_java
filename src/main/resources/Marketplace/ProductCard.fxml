<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<AnchorPane prefWidth="250.0" styleClass="panel-card" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Marketplace.ProductCardController">
   <children>
      <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <StackPane style="-fx-background-color: rgba(139, 92, 246, 0.05); -fx-background-radius: 8;">
               <children>
                  <ImageView fx:id="productImage" fitHeight="150.0" fitWidth="210.0" pickOnBounds="true" preserveRatio="true" />
               </children>
            </StackPane>
            <VBox spacing="5.0">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label fx:id="productName" styleClass="bento-title" text="Product Name" style="-fx-font-size: 18px;" />
                        <HBox HBox.hgrow="ALWAYS" />
                        <Label fx:id="productPrice" styleClass="headline" text="0.00 DT" style="-fx-font-size: 16px; -fx-text-fill: #8b5cf6;" />
                     </children>
                  </HBox>
                  <Label fx:id="productDescription" minHeight="40.0" styleClass="subheadline" text="Short description goes here..." wrapText="true" />
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label styleClass="subheadline" text="Stock:" />
                        <Label fx:id="productStock" styleClass="form-label" text="0" />
                        <HBox HBox.hgrow="ALWAYS" />
                        <Label fx:id="productCategory" style="-fx-background-color: rgba(186, 158, 255, 0.1); -fx-padding: 2 8; -fx-background-radius: 10; -fx-text-fill: #ba9eff; -fx-font-size: 10px;" text="Category" />
                     </children>
                  </HBox>
               </children>
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </VBox>
            <HBox spacing="10.0">
               <children>
                  <Button fx:id="btnEdit" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="edit-button" text="Edit" HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnDelete" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="delete-button" text="Delete" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
