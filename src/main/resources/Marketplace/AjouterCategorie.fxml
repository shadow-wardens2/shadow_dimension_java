<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="200.0" prefWidth="350.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.AjouterCategorieController">
    <children>
        <VBox alignment="CENTER" spacing="15" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            <Label styleClass="headline" text="Ajouter une Catégorie" />
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label styleClass="form-label" text="Nom de la catégorie:" prefWidth="120" />
                <TextField fx:id="tfNomCategorie" promptText="Entrer le nom" />
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label styleClass="form-label" text="Description:" prefWidth="120" />
                <TextField fx:id="tfDescription" promptText="Entrer la description" />
            </HBox>

            <HBox alignment="CENTER" spacing="10">
                <Button fx:id="btnAjouter" onAction="#ajouterCategorie" styleClass="glow-button" text="Ajouter" />
                <Button fx:id="btnAnnuler" onAction="#annuler" styleClass="secondary-button" text="Annuler" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>
