<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<AnchorPane prefHeight="250.0" prefWidth="450.0" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Marketplace.Back.AjouterTypeController">
    <children>
        <VBox alignment="CENTER" spacing="15" AnchorPane.leftAnchor="30" AnchorPane.rightAnchor="30" AnchorPane.topAnchor="20">
            <Label styleClass="headline" text="Ajouter un Type" />
            
            <Label fx:id="errorLabel" styleClass="error-text" visible="false" />

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefWidth="80" styleClass="form-label" text="Nom:" />
                <TextField fx:id="tfNomType" prefWidth="250" promptText="Entrer le nom du type" />
            </HBox>
            
            <HBox alignment="CENTER" spacing="20">
                <Button onAction="#handleAjouterType" styleClass="glow-button" text="Ajouter" />
                <Button onAction="#handleAnnuler" styleClass="secondary-button" text="Annuler" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>

