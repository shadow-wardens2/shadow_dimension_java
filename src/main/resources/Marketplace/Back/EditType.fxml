<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<AnchorPane prefHeight="220.0" prefWidth="450.0" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Marketplace.EditTypeController">
    <children>
        <VBox alignment="CENTER" spacing="15" AnchorPane.leftAnchor="30" AnchorPane.rightAnchor="30" AnchorPane.topAnchor="20">
            <Label styleClass="headline" text="Editer le Type" />
            
            <Label fx:id="errorLabel" styleClass="error-text" visible="false" />

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefWidth="80" styleClass="form-label" text="Nom:" />
                <TextField fx:id="tfNom" prefWidth="250" promptText="Entrer le nom" />
            </HBox>
            <HBox alignment="CENTER" spacing="20">
                <Button onAction="#sauvegarder" styleClass="glow-button" text="Enregistrer" />
                <Button onAction="#annuler" styleClass="secondary-button" text="Annuler" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>

