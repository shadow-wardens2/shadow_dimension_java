<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<AnchorPane prefHeight="320.0" prefWidth="500.0" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Marketplace.Back.AjouterCategorieController">
    <children>
        <VBox alignment="CENTER" spacing="15" AnchorPane.leftAnchor="30" AnchorPane.rightAnchor="30" AnchorPane.topAnchor="20">
            <Label styleClass="headline" text="Ajouter une Catégorie" />
            
            <Label fx:id="errorLabel" styleClass="error-text" visible="false" />

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefWidth="150" styleClass="form-label" text="Nom de la catégorie:" />
                <TextField fx:id="tfNomCategorie" prefWidth="250" promptText="Entrer le nom" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefWidth="150" styleClass="form-label" text="Description:" />
                <TextField fx:id="tfDescription" prefWidth="250" promptText="Entrer la description" />
            </HBox>

            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="btnAjouter" onAction="#ajouterCategorie" styleClass="glow-button" text="Ajouter" />
                <Button fx:id="btnAnnuler" onAction="#annuler" styleClass="secondary-button" text="Annuler" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>

