<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="180.0" prefWidth="280.0" styleClass="panel-card" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Marketplace.CategoryCardController">
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label fx:id="categoryName" styleClass="bento-title" text="Category Name">
                     <font>
                        <Font size="20.0" />
                     </font>
                  </Label>
                  <Pane HBox.hgrow="ALWAYS" />
                  <Label fx:id="categoryId" styleClass="subheadline" text="#0" />
               </children>
            </HBox>
            <Label fx:id="categoryDescription" styleClass="subheadline" text="Category description goes here..." wrapText="true" VBox.vgrow="ALWAYS" />
            <Pane VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleEdit" prefWidth="80.0" styleClass="edit-button" text="Edit" />
                  <Button mnemonicParsing="false" onAction="#handleDelete" prefWidth="80.0" styleClass="delete-button" text="Delete" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
   </padding>
</AnchorPane>
