<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="800.0" prefWidth="1280.0" style="-fx-background-color: #050507;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.User.HomePageController">

    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: rgba(5,5,7,0.8); -fx-border-width: 0 0 1 0; -fx-border-color: #1a1a24;">
                <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 48 0 48;">
                    <Label style="-fx-font-size: 20px; -fx-text-fill: #fcf8fc;" styleClass="headline" text="Shadow" />
                    <Label style="-fx-font-size: 20px;" styleClass="headline" text="Dimensions" />
                </HBox>
                <Pane HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="40" />
                <Pane HBox.hgrow="ALWAYS" />
                <Button fx:id="btnTopAuth" onAction="#handleAuthAction" style="-fx-translate-x: -48;" styleClass="glow-button" text="Connect Soul" />
            </HBox>
        </top>

        <left>
            <VBox prefWidth="256.0" style="-fx-background-color: #050507; -fx-border-width: 0 1 0 0; -fx-border-color: #1a1a24;">
                <VBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 24 24 40 24;">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane prefHeight="40" prefWidth="40">
                            <children>
                                <Label fx:id="lbUserAvatar" alignment="CENTER" prefHeight="40" prefWidth="40" style="-fx-background-color: #19191d; -fx-background-radius: 20; -fx-text-fill: #ffffff; -fx-font-weight: bold;" text="SD" />
                                <ImageView fx:id="imgUserAvatar" fitHeight="40" fitWidth="40" preserveRatio="false" />
                            </children>
                        </StackPane>
                        <VBox alignment="CENTER_LEFT">
                            <Label fx:id="lbUserName" style="-fx-text-fill: #ffffff; -fx-font-family: 'Cinzel', serif; -fx-font-weight: bold; -fx-font-size: 14px;" text="Shadow Dweller" />
                            <Label style="-fx-text-fill: #8b5cf6; -fx-font-size: 10px; -fx-font-weight: bold;" text="TIER: ETHEREAL" />
                        </VBox>
                    </HBox>
                </VBox>
                <VBox spacing="8" style="-fx-padding: 0 0 0 0;">
                    <Button alignment="BASELINE_LEFT" onAction="#openFrontOffice" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    Front Office" />
                    <Button alignment="BASELINE_LEFT" onAction="#openHome" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    Home" />
                    <Button alignment="BASELINE_LEFT" onAction="#openVault" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    My Vault" />
                    <Button fx:id="btnUserManagement" alignment="BASELINE_LEFT" managed="false" onAction="#openUserManagement" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    Users Management" visible="false" />
                    <Button fx:id="btnUserStatistics" alignment="BASELINE_LEFT" managed="false" onAction="#openUserStatistics" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    Users Statistics" visible="false" />
                    <Button alignment="BASELINE_LEFT" onAction="#openMarketplaceManagement" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    Marketplace Management" />
                    <Button alignment="BASELINE_LEFT" onAction="#openMarketplaceStatistics" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    Marketplace Statistics" />
                    <Button alignment="BASELINE_LEFT" onAction="#openTutorialsManagement" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    Tutorials Management" />
                    <Button alignment="BASELINE_LEFT" onAction="#openEventManagement" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    Event Management" />
                    <Button fx:id="btnForumManagement" alignment="BASELINE_LEFT" onAction="#openForumManagement" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    Forum Management" />
                    <Button fx:id="btnForumCategoryManagement" alignment="BASELINE_LEFT" onAction="#openForumCategoryManagement" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    Forum Categories" />
                    <Button fx:id="btnForumStatistics" alignment="BASELINE_LEFT" onAction="#openForumStatistics" prefHeight="45" prefWidth="256" styleClass="sidebar-btn" text="    Forum Statistics" />
                </VBox>
                <Pane VBox.vgrow="ALWAYS" />
                <VBox style="-fx-padding: 24;">
                    <Button fx:id="btnBottomAuth" onAction="#handleAuthAction" prefWidth="208" styleClass="secondary-button" text="Connect Soul" />
                </VBox>
            </VBox>
        </left>

        <center>
            <StackPane fx:id="contentArea" style="-fx-background-color: #050507;" />
        </center>
    </BorderPane>

    <StackPane alignment="BOTTOM_RIGHT" mouseTransparent="true">
        <Button mouseTransparent="false" prefHeight="56" prefWidth="56" style="-fx-translate-x: -32; -fx-translate-y: -32;" styleClass="chat-toggle" text="💬" />
    </StackPane>

</StackPane>
