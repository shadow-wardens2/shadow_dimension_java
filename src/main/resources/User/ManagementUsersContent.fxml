<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" stylesheets="@../style.css" style="-fx-background-color: #050507; -fx-padding: 22;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.User.ManagementUsersController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <children>
                <TextField fx:id="tfSearch" prefWidth="640.0" promptText="Search by name, role or ID..." />
                <Pane HBox.hgrow="ALWAYS" />
                <Button fx:id="btnSortId" onAction="#handleToggleSortById" styleClass="secondary-button" text="ID DESC" />
                <Button onAction="#handleRefresh" styleClass="secondary-button" text="Refresh" />
            </children>
        </HBox>

        <TableView fx:id="usersTable" prefHeight="520.0" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="colUserIdentity" prefWidth="360.0" text="User Identity" />
                <TableColumn fx:id="colRank" prefWidth="180.0" text="Rank" />
                <TableColumn fx:id="colStatus" prefWidth="160.0" text="Status" />
                <TableColumn fx:id="colLastPresence" prefWidth="180.0" text="Last Presence" />
                <TableColumn fx:id="colActions" prefWidth="320.0" text="Actions" />
            </columns>
        </TableView>
    </children>
</VBox>
