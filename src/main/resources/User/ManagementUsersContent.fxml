<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" stylesheets="@../style.css" style="-fx-background-color: #050507; -fx-padding: 22;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.User.ManagementUsersController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <children>
                <Label styleClass="headline" text="Users Management" />
                <Pane HBox.hgrow="ALWAYS" />
                <Button onAction="#handleRefresh" styleClass="secondary-button" text="Refresh" />
            </children>
        </HBox>

        <TableView fx:id="usersTable" prefHeight="260.0" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="colUsername" prefWidth="170.0" text="Username" />
                <TableColumn fx:id="colEmail" prefWidth="220.0" text="Email" />
                <TableColumn fx:id="colRoles" prefWidth="170.0" text="Roles" />
                <TableColumn fx:id="colActive" prefWidth="90.0" text="Active" />
                <TableColumn fx:id="colLocked" prefWidth="90.0" text="Locked" />
            </columns>
        </TableView>

        <VBox spacing="12.0" styleClass="panel-card">
            <children>
                <Label styleClass="bento-title" text="Edit Selected User" />
                <GridPane hgap="12.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="110.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints prefWidth="110.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>

                    <Label styleClass="form-label" text="Email" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="tfEmail" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label styleClass="form-label" text="Username" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                    <TextField fx:id="tfUsername" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                    <Label styleClass="form-label" text="Roles" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField fx:id="tfRoles" promptText="[&quot;ROLE_USER&quot;] or ROLE_ADMIN" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label styleClass="form-label" text="Full Name" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                    <TextField fx:id="tfFullName" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                    <Label styleClass="form-label" text="Phone" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="tfPhone" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label styleClass="form-label" text="Country" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                    <TextField fx:id="tfCountry" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                    <Label styleClass="form-label" text="City" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <TextField fx:id="tfCity" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <Label styleClass="form-label" text="Bio" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                    <TextArea fx:id="taBio" prefHeight="80.0" wrapText="true" GridPane.columnIndex="3" GridPane.rowIndex="3" />

                    <HBox spacing="18.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                        <children>
                            <CheckBox fx:id="cbActive" styleClass="form-label" text="Active" />
                            <CheckBox fx:id="cbLocked" styleClass="form-label" text="Locked" />
                        </children>
                    </HBox>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button onAction="#handleDeleteUser" styleClass="secondary-button" text="Delete User" />
                        <Button onAction="#handleSaveUser" styleClass="glow-button" text="Save Changes" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
