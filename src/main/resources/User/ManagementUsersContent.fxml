<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" stylesheets="@../style.css" style="-fx-background-color: #050507; -fx-padding: 22;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.User.ManagementUsersController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <children>
                <TextField fx:id="tfSearch" prefWidth="640.0" promptText="Search by name, email, role or status..." styleClass="search-field" />
                <Pane HBox.hgrow="ALWAYS" />
                <Button onAction="#handleExportPdf" styleClass="secondary-button" text="Export PDF" />
                <Button fx:id="btnSortId" onAction="#handleToggleSortById" styleClass="secondary-button" text="Newest First" />
                <Button onAction="#handleRefresh" styleClass="secondary-button" text="Refresh" />
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" pannable="true" prefHeight="520.0" style="-fx-background-color: transparent;">
            <content>
                <VBox fx:id="usersContainer" spacing="10.0" />
            </content>
        </ScrollPane>
    </children>
</VBox>
