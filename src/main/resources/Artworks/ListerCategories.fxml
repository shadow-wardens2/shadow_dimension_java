<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="24" style="-fx-background-color: #050507; -fx-padding: 32;" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Artworks.ListerCategoriesController">
    <HBox alignment="CENTER_LEFT" spacing="24">
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Text style="-fx-font-family: 'Cinzel', serif; -fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #ba9eff;" text="MANAGE CATEGORIES" />
        </VBox>
        <Button onAction="#navigateToAdd" styleClass="glow-button" text="+ Add New Category" />
        <Button onAction="#goBack" styleClass="secondary-button" text="Back to Artworks" />
    </HBox>

    <TableView fx:id="categoriesTable" styleClass="table-view" prefHeight="400">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50" />
            <TableColumn fx:id="colName" text="Name" prefWidth="250" />
            <TableColumn fx:id="colDescription" text="Description" prefWidth="350" />
            <TableColumn fx:id="colActions" text="Actions" prefWidth="150" />
        </columns>
    </TableView>
</VBox>
