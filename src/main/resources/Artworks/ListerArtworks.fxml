<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Artworks.ListerArtworksController">
    <VBox spacing="48" style="-fx-background-color: #050507; -fx-padding: 48 48 48 48;">
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="24">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Text style="-fx-font-family: 'Cinzel', serif; -fx-font-size: 36px; -fx-font-weight: 900; -fx-fill: #fcf8fc;" text="ARTWORKS MANAGEMENT" />
                <Label style="-fx-text-fill: #adaaae; -fx-font-size: 14px;" text="Manage all your digital and physical artworks." />
            </VBox>
            <Button onAction="#navigateToCategories" styleClass="glow-button" text="Manage Categories" />
            <Button onAction="#navigateToAdd" styleClass="glow-button" text="+ Add New Artwork" />
        </HBox>

        <HBox spacing="16">
            <TextField fx:id="searchField" promptText="Search artworks..." styleClass="search-field" prefWidth="300" />
            <ComboBox fx:id="filterCategory" promptText="Sort By Category" styleClass="combo-box" prefWidth="200" />
            <ComboBox fx:id="sortOptions" promptText="Sort By..." styleClass="combo-box" prefWidth="200" />
        </HBox>

        <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <FlowPane fx:id="artworksGrid" hgap="24" vgap="24" style="-fx-padding: 10;">
                <!-- Cards will be injected here -->
            </FlowPane>
        </ScrollPane>
    </VBox>
</ScrollPane>
