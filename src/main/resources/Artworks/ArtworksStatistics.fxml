<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="ALWAYS" styleClass="scroll-pane" style="-fx-background-color: #050507;" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Artworks.ArtworksStatisticsController">
    <VBox spacing="30" style="-fx-background-color: #050507; -fx-padding: 40 40 100 40;">
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox spacing="5">
                <Label styleClass="display-lg" text="ARTWORKS ANALYTICS" style="-fx-font-size: 32px;" />
                <Label styleClass="subheadline" text="Behold the patterns within the Shadow Dimension" />
            </VBox>
        </HBox>

        <!-- Stats Overview Cards -->
        <HBox spacing="30">
            <VBox styleClass="artifact-card" prefWidth="280" alignment="CENTER" spacing="10">
                <Label text="TOTAL RELICS" styleClass="label-sigil" opacity="0.6" />
                <Label fx:id="lbTotalArtworks" text="0" style="-fx-font-size: 36px; -fx-text-fill: #ffffff; -fx-font-weight: bold;" />
            </VBox>
            <VBox styleClass="artifact-card" prefWidth="280" alignment="CENTER" spacing="10">
                <Label text="ETHEREAL VALUE" styleClass="label-sigil" opacity="0.6" />
                <Label fx:id="lbTotalValue" text="0 ETH" style="-fx-font-size: 36px; -fx-text-fill: #8b5cf6; -fx-font-weight: bold;" />
            </VBox>
            <VBox styleClass="artifact-card" prefWidth="280" alignment="CENTER" spacing="10">
                <Label text="ACTIVE REALMS" styleClass="label-sigil" opacity="0.6" />
                <Label fx:id="lbTotalCategories" text="0" style="-fx-font-size: 36px; -fx-text-fill: #ffffff; -fx-font-weight: bold;" />
            </VBox>
        </HBox>

        <!-- Main Chart -->
        <VBox styleClass="artifact-card" spacing="20" alignment="CENTER">
            <Label text="RELIC DISTRIBUTION BY REALM" style="-fx-font-family: 'Cinzel', serif; -fx-text-fill: #ba9eff; -fx-font-size: 22px;" />
            <PieChart fx:id="pieChartCategories" style="-fx-pie-label-visible: true;" legendSide="BOTTOM" prefHeight="450" />
        </VBox>

        <!-- Detailed Category Stats -->
        <VBox spacing="15">
            <Label text="REALM DETAILS" style="-fx-font-family: 'Cinzel', serif; -fx-text-fill: #8b5cf6; -fx-font-size: 18px;" />
            <FlowPane fx:id="categoryStatsPane" hgap="20" vgap="20" prefWrapLength="1000" />
        </VBox>

        <!-- AI Advisor Section -->
        <HBox fx:id="aiAdvisorContainer" spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: rgba(139, 92, 246, 0.1); -fx-padding: 20; -fx-background-radius: 20; -fx-border-color: #8b5cf6; -fx-border-radius: 20; -fx-border-width: 0.5;">
            <StackPane>
                <Region prefHeight="50" prefWidth="50" style="-fx-background-color: #ffffff; -fx-background-radius: 25; -fx-opacity: 0.8;" />
                <Label text="👻" style="-fx-font-size: 24px;" />
            </StackPane>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="SHADOW ADVISOR" style="-fx-text-fill: #8b5cf6; -fx-font-weight: bold; -fx-font-size: 14px;" />
                <Label fx:id="lbAiSuggestion" text="Analyzing the void..." wrapText="true" style="-fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-font-style: italic;" />
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
