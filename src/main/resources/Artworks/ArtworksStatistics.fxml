<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.Group?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="ALWAYS" styleClass="scroll-pane" style="-fx-background-color: #050507;" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Artworks.ArtworksStatisticsController">
    <VBox spacing="35" style="-fx-background-color: #050507; -fx-padding: 40 40 100 40;">
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox spacing="5">
                <Label styleClass="display-lg" text="DIMENSIONAL ANALYTICS" style="-fx-font-size: 36px; -fx-text-fill: linear-gradient(to right, #ffffff, #8b5cf6);" />
                <Label styleClass="subheadline" text="Manifestation patterns and ethereal flow within the Shadow Realms" />
            </VBox>
        </HBox>

        <!-- Stats Overview Cards -->
        <HBox spacing="30">
            <VBox styleClass="artifact-card" prefWidth="300" alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS">
                <Label text="TOTAL RELICS" styleClass="label-sigil" opacity="0.6" />
                <Label fx:id="lbTotalArtworks" text="0" style="-fx-font-size: 42px; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-family: 'Cinzel', serif;" />
                <Region prefHeight="5" style="-fx-background-color: rgba(139, 92, 246, 0.3); -fx-background-radius: 2;" />
            </VBox>
            <VBox styleClass="artifact-card" prefWidth="300" alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS">
                <Label text="ETHEREAL VALUE" styleClass="label-sigil" opacity="0.6" />
                <Label fx:id="lbTotalValue" text="0 ETH" style="-fx-font-size: 42px; -fx-text-fill: #8b5cf6; -fx-font-weight: bold; -fx-font-family: 'Cinzel', serif;" />
                <Region prefHeight="5" style="-fx-background-color: #8b5cf6; -fx-background-radius: 2;" />
            </VBox>
            <VBox styleClass="artifact-card" prefWidth="300" alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS">
                <Label text="ACTIVE REALMS" styleClass="label-sigil" opacity="0.6" />
                <Label fx:id="lbTotalCategories" text="0" style="-fx-font-size: 42px; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-family: 'Cinzel', serif;" />
                <Region prefHeight="5" style="-fx-background-color: rgba(139, 92, 246, 0.3); -fx-background-radius: 2;" />
            </VBox>
        </HBox>

        <!-- Charts Row -->
        <GridPane hgap="30" vgap="30">
            <columnConstraints>
                <ColumnConstraints percentWidth="50" />
                <ColumnConstraints percentWidth="50" />
            </columnConstraints>
            
            <!-- Distribution Chart -->
            <VBox styleClass="artifact-card" spacing="20" alignment="CENTER" GridPane.columnIndex="0">
                <Label text="RELIC POPULATION" style="-fx-font-family: 'Cinzel', serif; -fx-text-fill: #ba9eff; -fx-font-size: 20px;" />
                <PieChart fx:id="pieChartCategories" style="-fx-pie-label-visible: true;" legendSide="BOTTOM" prefHeight="400" />
            </VBox>
            
            <!-- Value Chart -->
            <VBox styleClass="artifact-card" spacing="20" alignment="CENTER" GridPane.columnIndex="1">
                <Label text="REALM MARKET VALUE (USD)" style="-fx-font-family: 'Cinzel', serif; -fx-text-fill: #ba9eff; -fx-font-size: 20px;" />
                <BarChart fx:id="barChartValue" animated="false" legendVisible="false" prefHeight="400">
                    <xAxis><CategoryAxis side="BOTTOM" tickLabelFill="WHITE" /></xAxis>
                    <yAxis><NumberAxis side="LEFT" tickLabelFill="WHITE" /></yAxis>
                </BarChart>
            </VBox>
        </GridPane>

        <!-- Detailed Category Stats -->
        <VBox spacing="20">
            <Label text="REALM ARCHIVES" style="-fx-font-family: 'Cinzel', serif; -fx-text-fill: #8b5cf6; -fx-font-size: 18px;" />
            <FlowPane fx:id="categoryStatsPane" hgap="25" vgap="25" prefWrapLength="1200" />
        </VBox>

        <!-- AI Advisor Section -->
        <HBox fx:id="aiAdvisorContainer" spacing="25" alignment="CENTER_LEFT" style="-fx-background-color: rgba(26, 26, 36, 0.8); -fx-padding: 30; -fx-background-radius: 24; -fx-border-color: rgba(139, 92, 246, 0.4); -fx-border-radius: 24; -fx-border-width: 1;">
            <effect>
                <DropShadow color="#8b5cf633" radius="20" />
            </effect>
            <StackPane prefHeight="100" prefWidth="100" style="-fx-background-color: transparent;">
                <!-- Ethereal Glow Aura -->
                <Circle radius="40" fill="rgba(139, 92, 246, 0.1)">
                    <effect><GaussianBlur radius="15" /></effect>
                </Circle>
                
                <!-- The Shadow Ghost -->
                <Group scaleX="0.7" scaleY="0.7">
                    <VBox alignment="CENTER" style="-fx-background-color: transparent;">
                        <StackPane style="-fx-background-color: transparent;">
                            <!-- Ghost Body - Hand-crafted SVG -->
                            <SVGPath content="M50,5 C25,5 5,25 5,55 C5,85 5,105 5,105 L20,95 L35,105 L50,95 L65,105 L80,95 L95,105 L95,55 C95,25 75,5 50,5 Z" stroke="#8b5cf6" strokeWidth="2.5">
                                <fill>
                                    <LinearGradient endX="0" endY="1" startX="0" startY="0">
                                        <stops>
                                            <Stop color="#8b5cf6" offset="0.0" />
                                            <Stop color="#2d1b4d" offset="1.0" />
                                        </stops>
                                    </LinearGradient>
                                </fill>
                            </SVGPath>
                            
                            <!-- Ethereal Eyes -->
                            <HBox alignment="CENTER" spacing="15" translateY="-10">
                                <Circle radius="6" fill="#050507" />
                                <Circle radius="6" fill="#050507" />
                            </HBox>
                            
                            <!-- Pupil Glow -->
                            <HBox alignment="CENTER" spacing="22" translateY="-12">
                                <Circle radius="2" fill="#ba9eff" />
                                <Circle radius="2" fill="#ba9eff" />
                            </HBox>
                        </StackPane>
                    </VBox>
                </Group>
            </StackPane>
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="SHADOW CURATOR'S INSIGHT" style="-fx-text-fill: #8b5cf6; -fx-font-weight: bold; -fx-font-size: 14px; -fx-letter-spacing: 2;" />
                <Label fx:id="lbAiSuggestion" text="The void is shifting... calculating dimensional balance." wrapText="true" style="-fx-text-fill: #e2e8f0; -fx-font-size: 17px; -fx-font-style: italic; -fx-line-spacing: 1.4;" />
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
