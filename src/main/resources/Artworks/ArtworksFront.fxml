<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane fx:id="rootNode" prefHeight="900.0" prefWidth="1440.0" style="-fx-background-color: #050507;" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Artworks.ArtworksFrontController">
    <children>
        <!-- Atmospheric Background -->
        <Pane opacity="0.4" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <style>
                -fx-background-color: radial-gradient(center 50% 50%, radius 80%, rgba(139, 92, 246, 0.05), transparent);
            </style>
        </Pane>

        <VBox spacing="40" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <padding>
                <Insets bottom="60.0" left="60.0" right="60.0" top="40.0" />
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="24">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label styleClass="label-sigil" text="ETHEREAL GALLERY" />
                    <Label styleClass="display-lg" text="SHADOW ARTWORKS" style="-fx-font-size: 48;" />
                    <Label styleClass="body-md" text="Explore the collection of cursed and divine relics from the void." opacity="0.6" />
                </VBox>
                <Button onAction="#handleBack" styleClass="secondary-button" text="← Return to Void" />
            </HBox>

            <!-- Filters -->
            <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: rgba(26, 26, 36, 0.5); -fx-padding: 20; -fx-background-radius: 16;">
                <TextField fx:id="searchField" promptText="Search the void..." styleClass="search-field" prefWidth="400" />
                <ComboBox fx:id="filterCategory" promptText="All Realms" styleClass="combo-box" prefWidth="200" />
                <ComboBox fx:id="sortOptions" promptText="Order of Manifestation" styleClass="combo-box" prefWidth="250" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="itemCountLabel" styleClass="label-sigil" text="0 RELICS FOUND" opacity="0.5" />
            </HBox>

            <!-- Artworks Grid -->
            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                <FlowPane fx:id="artworksGrid" hgap="30" vgap="30" alignment="TOP_LEFT">
                    <padding>
                        <Insets bottom="20" left="10" right="10" top="10" />
                    </padding>
                    <!-- FrontArtworkCard will be injected here -->
                </FlowPane>
            </ScrollPane>
        </VBox>
    </children>
</AnchorPane>
