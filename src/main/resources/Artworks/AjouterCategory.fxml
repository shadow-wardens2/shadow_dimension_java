<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox spacing="24" style="-fx-background-color: #050507; -fx-padding: 32;" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Artworks.AjouterCategoryController">
    <Text fx:id="titleText" style="-fx-font-family: 'Cinzel', serif; -fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #ba9eff;" text="ADD NEW CATEGORY" />

    <GridPane hgap="16" vgap="16">
        <columnConstraints>
            <ColumnConstraints minWidth="100" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <Label styleClass="form-label" text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtName" promptText="Category Name" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label styleClass="form-label" text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextArea fx:id="txtDescription" promptText="Detailed description" styleClass="text-area" prefRowCount="4" GridPane.columnIndex="1" GridPane.rowIndex="1" />
    </GridPane>

    <HBox spacing="16" alignment="CENTER_RIGHT">
        <Button onAction="#handleCancel" styleClass="secondary-button" text="Cancel" />
        <Button fx:id="btnSave" onAction="#handleSave" styleClass="glow-button" text="Save Category" />
    </HBox>
</VBox>
