<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" prefWidth="520"
      style="-fx-background-color: #0f111a; -fx-padding: 36;"
      stylesheets="@../style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.Forum.EditPostController">

    <!-- Header -->
    <Label text="✎ Edit Scroll"
           style="-fx-font-family: 'Cinzel', serif; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ba9eff;"/>
    <Label text="Refine your words before the order reads them"
           style="-fx-text-fill: #5a5070; -fx-font-size: 13px;"/>

    <!-- Separator -->
    <Region prefHeight="1" style="-fx-background-color: rgba(139,92,246,0.15);"/>

    <!-- Title -->
    <VBox spacing="6">
        <Label text="Title" styleClass="form-label"/>
        <TextField fx:id="tfTitle" promptText="Name your scroll…" styleClass="text-field"/>
    </VBox>

    <!-- Category -->
    <VBox spacing="6">
        <Label text="Category" styleClass="form-label"/>
        <ComboBox fx:id="cbCategory" maxWidth="Infinity" styleClass="combo-box"/>
    </VBox>

    <!-- Content -->
    <VBox spacing="6" VBox.vgrow="ALWAYS">
        <Label text="Content" styleClass="form-label"/>
        <TextArea fx:id="taContent" prefRowCount="6" styleClass="text-area"/>
    </VBox>

    <!-- Image URL -->
    <VBox spacing="6">
        <Label text="Image URL (optional)" styleClass="form-label"/>
        <TextField fx:id="tfImageUrl" promptText="https://…" styleClass="text-field"/>
    </VBox>

    <!-- Error -->
    <Label fx:id="lblError" styleClass="validation-error" text="" managed="false" visible="false" wrapText="true"/>

    <!-- Buttons -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button onAction="#handleCancel" styleClass="secondary-button" text="Cancel"
                style="-fx-border-radius: 30; -fx-background-radius: 30; -fx-padding: 10 24;"/>
        <Button onAction="#handleSave" styleClass="glow-button" text="Save Changes"/>
    </HBox>
</VBox>
