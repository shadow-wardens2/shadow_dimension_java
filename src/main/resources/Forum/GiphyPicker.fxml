<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="450.0" 
            style="-fx-background-color: #0f111a; -fx-border-color: #8b5cf6; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="Controllers.Forum.GiphyPickerController">

    <top>
        <VBox spacing="10" style="-fx-padding: 15;">
            <HBox spacing="10">
                <TextField fx:id="txtSearch" promptText="Search Giphy..." HBox.hgrow="ALWAYS" 
                           style="-fx-background-color: #1a1c23; -fx-text-fill: #e8e0eb; -fx-prompt-text-fill: #5a5070; -fx-border-color: rgba(139,92,246,0.5); -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;"/>
                <Button fx:id="btnSearch" text="Search" onAction="#handleSearch" 
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #0f111a;" 
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <FlowPane fx:id="gifGrid" hgap="10" vgap="10" style="-fx-padding: 15; -fx-background-color: #0f111a;"/>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 15;">
            <Button text="Close" onAction="#handleClose" 
                    style="-fx-background-color: transparent; -fx-text-fill: #adaaae; -fx-cursor: hand; -fx-font-weight: bold;"/>
        </HBox>
    </bottom>

</BorderPane>
