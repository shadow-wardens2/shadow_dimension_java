<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="900.0" prefWidth="1100.0"
            style="-fx-background-color: #050507;"
            stylesheets="@../style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.Forum.UserProfileController">

    <!-- Top Bar -->
    <HBox alignment="CENTER_LEFT" prefHeight="72.0" spacing="20"
          style="-fx-background-color: rgba(5,5,7,0.95); -fx-border-width: 0 0 1 0; -fx-border-color: rgba(139,92,246,0.12);"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <padding><Insets left="60.0" right="60.0"/></padding>
        <Button fx:id="btnBack" onAction="#handleBack" styleClass="secondary-button"
                text="← Back to Dimension"
                style="-fx-border-radius: 30; -fx-background-radius: 30; -fx-padding: 10 20;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label styleClass="headline" text="Shadow" style="-fx-font-size: 18px;"/>
        <Label styleClass="headline" text="Dimensions" style="-fx-font-size: 18px; -fx-padding: 0 0 0 -32;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="scroll-pane"
                AnchorPane.topAnchor="72" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <content>
            <VBox spacing="30">
                <padding><Insets top="40" bottom="60" left="180" right="180"/></padding>

                <!-- Profile Header Card -->
                <VBox alignment="CENTER" spacing="16"
                      style="-fx-background-color: #0f111a; -fx-border-color: rgba(139,92,246,0.15); -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 40;">
                    
                    <ImageView fx:id="imgAvatar" fitWidth="120" fitHeight="120">
                        <clip>
                            <Circle centerX="60" centerY="60" radius="60"/>
                        </clip>
                    </ImageView>
                    
                    <Label fx:id="lblUsername" text="Username"
                           style="-fx-font-family: 'Cinzel', serif; -fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #e8e0eb;"/>
                    
                    <Label text="Warden of the Dimension"
                           style="-fx-text-fill: #8b5cf6; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                           
                    <Label fx:id="lblPostCount" text="0 Scrolls Inscribed"
                           style="-fx-text-fill: #5a5070; -fx-font-size: 14px;"/>
                </VBox>

                <Label text="Scrolls by this Warden"
                       style="-fx-font-family: 'Cinzel', serif; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ba9eff;"/>

                <!-- Posts List -->
                <VBox fx:id="postsContainer" spacing="16"/>

            </VBox>
        </content>
    </ScrollPane>
</AnchorPane>
