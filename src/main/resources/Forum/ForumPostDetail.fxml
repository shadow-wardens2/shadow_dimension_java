<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="900.0" prefWidth="1100.0"
            style="-fx-background-color: #050507;"
            stylesheets="@../style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.Forum.ForumPostDetailController">

    <!-- Top Bar -->
    <HBox alignment="CENTER_LEFT" prefHeight="72.0" spacing="20"
          style="-fx-background-color: rgba(5,5,7,0.95); -fx-border-width: 0 0 1 0; -fx-border-color: rgba(139,92,246,0.12);"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <padding><Insets left="60.0" right="60.0"/></padding>
        <Button fx:id="btnBack" onAction="#handleBack" styleClass="secondary-button"
                text="← Back to Scrolls"
                style="-fx-border-radius: 30; -fx-background-radius: 30; -fx-padding: 10 20;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label styleClass="headline" text="Shadow" style="-fx-font-size: 18px;"/>
        <Label styleClass="headline" text="Dimensions" style="-fx-font-size: 18px; -fx-padding: 0 0 0 -32;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="scroll-pane"
                AnchorPane.topAnchor="72" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <content>
            <VBox spacing="24">
                <padding><Insets top="40" bottom="60" left="120" right="120"/></padding>

                <!-- Post Header Card -->
                <HBox spacing="0"
                      style="-fx-background-color: #0f111a; -fx-border-color: rgba(139,92,246,0.15); -fx-border-radius: 16; -fx-background-radius: 16;">

                    <!-- Post Content -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS" style="-fx-padding: 24 28 24 24;">
                        <!-- Category + meta -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label fx:id="lblCategory" text="General"
                                   style="-fx-background-color: rgba(139,92,246,0.15); -fx-text-fill: #8b5cf6; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 3 10; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <Label fx:id="lblAuthor" text="author" style="-fx-text-fill: #5a5070; -fx-font-size: 12px;"/>
                            <Label fx:id="lblDate" text="" style="-fx-text-fill: #5a5070; -fx-font-size: 12px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnReport" onAction="#handleReport" text="🚩 Report" styleClass="ghost-button" style="-fx-text-fill: #ff4500; -fx-background-color: rgba(255,69,0,0.1); -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 3 10; -fx-cursor: hand; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- Title -->
                        <Label fx:id="lblTitle" text="Post Title"
                               style="-fx-font-family: 'Cinzel', serif; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #e8e0eb; -fx-wrap-text: true;"
                               wrapText="true"/>

                        <!-- Full Content -->
                        <Label fx:id="lblContent" text=""
                               style="-fx-text-fill: #adaaae; -fx-font-size: 14px; -fx-wrap-text: true; -fx-line-spacing: 4;"
                               wrapText="true"/>
                               
                        <!-- Image -->
                        <ImageView fx:id="postImageView" fitWidth="600" preserveRatio="true"/>
                        
                        <!-- Post Meta & Actions -->
                        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 10 0 0 0;">
                            <!-- Horizontal Vote Box (Reddit style) -->
                            <HBox alignment="CENTER" spacing="4" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 20; -fx-padding: 2 8;">
                                <Button fx:id="btnUp" onAction="#handleUpvote" text="⇧" styleClass="vote-button-up"/>
                                <Label fx:id="lblVotes" text="0" style="-fx-text-fill: #e8e0eb; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                                <Button fx:id="btnDown" onAction="#handleDownvote" text="⇩" styleClass="vote-button-down"/>
                            </HBox>
                            
                            <Label fx:id="lblCommentCount" text="0 Replies" style="-fx-text-fill: #adaaae; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnShare" onAction="#handleShare" text="↗ Share" styleClass="ghost-button" style="-fx-text-fill: #adaaae; -fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Comments Section -->
                <VBox spacing="16">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label fx:id="lblCommentCount" text="0 Replies"
                               style="-fx-font-family: 'Cinzel', serif; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ba9eff;"/>
                    </HBox>

                    <!-- Comment Cards (injected dynamically) -->
                    <VBox fx:id="commentsContainer" spacing="10"/>

                    <!-- Locked Message (Hidden by default) -->
                    <Label fx:id="lblLockedMessage" text="🔒 This scroll has been sealed by the wardens. No further replies can be inscribed."
                           style="-fx-font-family: 'Cinzel', serif; -fx-font-size: 14px; -fx-text-fill: #ff4500; -fx-font-weight: bold; -fx-padding: 20;"
                           visible="false" managed="false"/>

                    <!-- Add Reply Box -->
                    <VBox fx:id="replyBox" spacing="12" style="-fx-background-color: #0f111a; -fx-border-color: rgba(139,92,246,0.12); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 20;">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Add your voice to the void"
                                   style="-fx-font-family: 'Cinzel', serif; -fx-font-size: 13px; -fx-text-fill: #8b5cf6; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnAiCorrectReply" text="✨ Auto-Correct" onAction="#handleAiCorrectReply" style="-fx-background-color: rgba(245, 158, 11, 0.15); -fx-text-fill: #f59e0b; -fx-border-color: #f59e0b; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 4 12; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;"/>
                        </HBox>
                        <TextArea fx:id="taNewComment" promptText="Write your reply…" prefRowCount="3" styleClass="text-area"/>
                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnGiphy" onAction="#handleOpenGiphy" text="GIF" style="-fx-background-color: transparent; -fx-border-color: rgba(139,92,246,0.5); -fx-text-fill: #ba9eff; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-weight: bold;"/>
                            <Button fx:id="btnSubmitComment" onAction="#handleSubmitComment"
                                    styleClass="glow-button" text="Reply"/>
                        </HBox>
                    </VBox>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>
</AnchorPane>
