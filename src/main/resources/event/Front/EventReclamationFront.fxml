<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="640.0" prefWidth="980.0" spacing="12.0" style="-fx-padding: 16; -fx-background-color: #06070b;" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.event.Front.EventReclamationFrontController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleBackHome" styleClass="secondary-button" text="Home" />
                <Button mnemonicParsing="false" onAction="#handleBackEvents" styleClass="secondary-button" text="Events" />
                <Button mnemonicParsing="false" onAction="#handleBackMyEvents" styleClass="secondary-button" text="My Events" />
                <Button disable="true" mnemonicParsing="false" styleClass="glow-button" text="Complaints" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <VBox spacing="8.0" styleClass="artifact-card">
            <children>
                <Label styleClass="headline" text="Create Event Complaint" />
                <Label fx:id="lbHint" styleClass="subheadline" text="Only accepted reservations can be used to submit a complaint." />
                <ComboBox fx:id="cbEvent" prefWidth="520.0" promptText="Select accepted event" />
                <TextField fx:id="tfSubject" prefWidth="520.0" promptText="Subject" />
                <TextArea fx:id="taClaim" prefHeight="110.0" promptText="Describe the issue clearly and include key details..." wrapText="true" />
                <HBox spacing="10.0">
                    <children>
                        <Button onAction="#handleSubmit" styleClass="glow-button" text="Submit Complaint" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox spacing="8.0" styleClass="artifact-card" VBox.vgrow="ALWAYS">
            <children>
                <Label styleClass="headline" text="My Complaints" />
                <TableView fx:id="reclamationTable" prefHeight="360.0" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="65.0" text="ID" />
                        <TableColumn fx:id="colEvent" prefWidth="180.0" text="Event" />
                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
                        <TableColumn fx:id="colCreatedAt" prefWidth="170.0" text="Created" />
                        <TableColumn fx:id="colMessage" prefWidth="260.0" text="Message" />
                        <TableColumn fx:id="colAdminResponse" prefWidth="220.0" text="Admin Response" />
                        <TableColumn fx:id="colActions" prefWidth="120.0" text="Actions" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
