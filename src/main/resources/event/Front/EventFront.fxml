<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" style="-fx-padding: 18; -fx-background-color: #06070b;" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.event.Front.EventFrontController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleBackHome" styleClass="secondary-button" text="Home" />
                <Button disable="true" mnemonicParsing="false" styleClass="glow-button" text="Events" />
                <Button fx:id="btnMyEvents" onAction="#handleMyEvents" styleClass="secondary-button" text="My Events" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-padding: 4 0 0 0;">
            <children>
                <Label styleClass="headline" text="Events" />
                <Pane HBox.hgrow="ALWAYS" />
                <Label styleClass="subheadline" text="Reserve, review, and track accepted tickets" />
            </children>
        </HBox>

        <HBox spacing="10.0" style="-fx-padding: 0 0 4 0;">
            <children>
                <TextField fx:id="tfSearch" prefWidth="320.0" promptText="Search active events..." />
                <ComboBox fx:id="cbSort" prefWidth="220.0" />
            </children>
        </HBox>

        <TableView fx:id="eventTable" prefHeight="640.0" styleClass="table-view" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colTitle" prefWidth="230.0" text="Title" />
                <TableColumn fx:id="colLocation" prefWidth="180.0" text="Location" />
                <TableColumn fx:id="colDate" prefWidth="220.0" text="Start" />
                <TableColumn fx:id="colRating" prefWidth="130.0" text="Rating" />
                <TableColumn fx:id="colActions" prefWidth="250.0" text="Actions" />
            </columns>
        </TableView>
    </children>
</VBox>
