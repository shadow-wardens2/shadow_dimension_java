<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="560.0" prefWidth="950.0" spacing="12.0" style="-fx-padding: 18; -fx-background-color: #06070b;" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.event.Front.MyEventsController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleBackHome" styleClass="secondary-button" text="Home" />
                <Button mnemonicParsing="false" onAction="#handleBackToEvents" styleClass="secondary-button" text="Events" />
                <Button disable="true" mnemonicParsing="false" styleClass="glow-button" text="My Events" />
                <Button mnemonicParsing="false" onAction="#handleOpenReclamations" styleClass="secondary-button" text="Reclamations" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT">
            <children>
                <Label styleClass="headline" text="My Accepted Reservations" />
            </children>
        </HBox>

        <TableView fx:id="reservationTable" prefHeight="500.0" prefWidth="926.0" styleClass="table-view" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="70.0" text="ID" />
                <TableColumn fx:id="colEvent" prefWidth="290.0" text="Event" />
                <TableColumn fx:id="colReservedAt" prefWidth="220.0" text="Reserved At" />
                <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
                <TableColumn fx:id="colActions" prefWidth="220.0" text="Actions" />
            </columns>
        </TableView>
    </children>
</VBox>
