<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="30.0" stylesheets="@../style.css" style="-fx-background-color: #050507;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.event.EventSelectorController">
    <Label styleClass="headline" text="Event Protocol" />
    <Label styleClass="subheadline" text="Select event module you wish to configure" />
    <HBox alignment="CENTER" spacing="25.0" style="-fx-padding: 20 0 0 0;">
        <Button mnemonicParsing="false" onAction="#handleEvents" prefHeight="70.0" prefWidth="180.0" styleClass="glow-button" text="Manage Events" />
        <Button mnemonicParsing="false" onAction="#handleEventCategories" prefHeight="70.0" prefWidth="180.0" styleClass="secondary-button" text="Manage Categories" />
    </HBox>
</VBox>
