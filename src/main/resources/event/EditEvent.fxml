<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="640.0" prefWidth="700.0" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.event.EditEventController">
    <children>
        <VBox spacing="18.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label styleClass="headline" text="Editer Event" />

                <GridPane hgap="10" vgap="12">
                    <Label styleClass="form-label" text="Title:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="tfTitle" promptText="Event title" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label styleClass="form-label" text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextArea fx:id="taDescription" prefRowCount="3" promptText="Event description" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label styleClass="form-label" text="Location:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="tfLocation" promptText="Event location" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label styleClass="form-label" text="Start Date:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <DatePicker fx:id="dpStartDate" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label styleClass="form-label" text="End Date:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <DatePicker fx:id="dpEndDate" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                    <Label styleClass="form-label" text="Category:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <ComboBox fx:id="cbCategory" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                    <Label styleClass="form-label" text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <ComboBox fx:id="cbStatus" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                    <Label styleClass="form-label" text="Location Type:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                    <ComboBox fx:id="cbLocationType" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                    <Label styleClass="form-label" text="Capacity:" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                    <TextField fx:id="tfCapacity" promptText="Capacity > 0" GridPane.columnIndex="1" GridPane.rowIndex="8" />

                    <Label styleClass="form-label" text="Image URL:" GridPane.columnIndex="0" GridPane.rowIndex="9" />
                    <TextField fx:id="tfImage" promptText="https://example.com/image.png" GridPane.columnIndex="1" GridPane.rowIndex="9" />
                </GridPane>

                <Pane VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button onAction="#sauvegarder" styleClass="glow-button" text="Enregistrer" />
                    <Button onAction="#annuler" styleClass="secondary-button" text="Annuler" />
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
