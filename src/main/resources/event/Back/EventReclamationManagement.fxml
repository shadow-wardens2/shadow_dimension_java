<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="760.0" prefWidth="1200.0" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.event.Back.EventReclamationManagementController">
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background: transparent; -fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="12.0" style="-fx-padding: 16;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label styleClass="headline" text="Event Complaint Moderation" />
                                <Pane HBox.hgrow="ALWAYS" />
                                <TextField fx:id="tfSearch" prefWidth="240.0" promptText="Search user/event/status..." />
                                <ComboBox fx:id="cbStatus" prefWidth="150.0" />
                                <ComboBox fx:id="cbSort" prefWidth="150.0" />
                            </children>
                        </HBox>

                        <TableView fx:id="reclamationTable" prefHeight="460.0" styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                                <TableColumn fx:id="colUser" prefWidth="130.0" text="User" />
                                <TableColumn fx:id="colEvent" prefWidth="170.0" text="Event" />
                                <TableColumn fx:id="colStatus" prefWidth="110.0" text="Status" />
                                <TableColumn fx:id="colCreatedAt" prefWidth="170.0" text="Created" />
                                <TableColumn fx:id="colClaim" prefWidth="260.0" text="Message" />
                                <TableColumn fx:id="colAiSummary" prefWidth="250.0" text="AI Response" />
                                <TableColumn fx:id="colActions" prefWidth="80.0" text="Actions" />
                            </columns>
                        </TableView>

                        <VBox spacing="8.0" styleClass="artifact-card">
                            <children>
                                <Label styleClass="subheadline" text="Admin Response" />
                                <TextArea fx:id="taResponse" prefHeight="120.0" promptText="Write moderation response..." wrapText="true" />
                                <HBox spacing="10.0">
                                    <children>
                                        <ComboBox fx:id="cbAction" prefWidth="180.0" />
                                        <Button onAction="#handleSuggestAiResponse" styleClass="secondary-button" text="AI Suggestion" />
                                        <Button onAction="#handleApplyDecision" styleClass="glow-button" text="Apply Decision" />
                                        <Pane HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lbPageInfo" text="Page 1 / 1" />
                                        <Button onAction="#handlePrevPage" styleClass="secondary-button" text="Prev" />
                                        <Button onAction="#handleNextPage" styleClass="glow-button" text="Next" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
