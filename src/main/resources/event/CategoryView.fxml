<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="1000.0" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.event.CategoryController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleGoBack" styleClass="secondary-button" text="← Back" />
                        <Label styleClass="headline" text="Event Categories Management" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleExportPdf" styleClass="secondary-button" text="Export PDF" />
                        <Button mnemonicParsing="false" onAction="#handleAddCategory" styleClass="glow-button" text="+ Add Category" />
                    </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <TextField fx:id="tfSearch" promptText="Search categories..." prefWidth="320.0" />
                        <Button fx:id="btnMic" mnemonicParsing="false" onAction="#handleVoiceSearch" styleClass="icon-button" text="Mic" />
                        <ComboBox fx:id="cbSort" prefWidth="220.0" promptText="Sort by" />
                        <Pane HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
                <Label styleClass="form-label" text="ID / Name / Description / Pricing / Price / Actions" />
                <ScrollPane fitToWidth="true" prefHeight="500.0" styleClass="users-scroll" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="categoriesContainer" spacing="10.0" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
