<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="1100.0" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.event.EventController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Label styleClass="headline" text="Events Management" />
                  <Pane HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleExportPdf" styleClass="secondary-button" text="Export PDF" />
                  <Button mnemonicParsing="false" onAction="#handleAddEvent" styleClass="glow-button" text="+ Add Event" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <TextField fx:id="tfSearch" promptText="Search events..." prefWidth="320.0" />
                  <Button fx:id="btnMic" mnemonicParsing="false" onAction="#handleVoiceSearch" styleClass="icon-button" text="Mic" />
                  <ComboBox fx:id="cbSort" prefWidth="220.0" promptText="Sort by" />
                  <Pane HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
            <TableView fx:id="eventTable" prefHeight="500.0" prefWidth="1060.0" styleClass="table-view" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colTitle" prefWidth="130.0" text="Title" />
                <TableColumn fx:id="colDescription" prefWidth="160.0" text="Description" />
                <TableColumn fx:id="colLocation" prefWidth="100.0" text="Location" />
                <TableColumn fx:id="colStartDate" prefWidth="120.0" text="Start" />
                <TableColumn fx:id="colEndDate" prefWidth="120.0" text="End" />
                <TableColumn fx:id="colCapacity" prefWidth="80.0" text="Capacity" />
                <TableColumn fx:id="colCategory" prefWidth="110.0" text="Category" />
                <TableColumn fx:id="colStatus" prefWidth="90.0" text="Status" />
                <TableColumn fx:id="colLocationType" prefWidth="90.0" text="Type" />
                <TableColumn fx:id="colActions" prefWidth="180.0" text="Actions" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
