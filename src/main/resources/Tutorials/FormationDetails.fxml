<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="900.0" prefWidth="1440.0" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Tutorials.FormationDetailsController">
    <!-- Atmospheric Background -->
    <StackPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <Pane opacity="0.1" style="-fx-background-color: radial-gradient(center 50% 50%, radius 70%, #d3bbff12, transparent);" />
    </StackPane>

    <VBox spacing="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="40.0" style="-fx-background-color: rgba(16, 13, 20, 0.9); -fx-backdrop-filter: blur(20px);">
            <padding>
                <Insets left="60.0" right="60.0" />
            </padding>
            <Button onAction="#handleBack" styleClass="secondary-button" text="← Back to Archive" />
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="label-sigil" text="FORMATION PROTOCOL" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnEnroll" onAction="#handleEnroll" styleClass="ethereal-button" text="Enroll in Path" />
        </HBox>

        <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="50.0">
                    <padding>
                        <Insets bottom="100.0" left="100.0" right="100.0" top="60.0" />
                    </padding>

                    <!-- Formation Intro -->
                    <VBox spacing="20.0">
                        <Label fx:id="lbLevel" styleClass="label-sigil" text="LEVEL: BEGINNER" />
                        <Label fx:id="lbTitle" styleClass="display-lg" text="Formation Title" />
                        <Label fx:id="lbDescription" styleClass="body-md" text="Detailed description goes here..." wrapText="true" opacity="0.7" maxWidth="900" />
                    </VBox>

                    <HBox spacing="60.0">
                        <!-- Lessons Column -->
                        <VBox spacing="30.0" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Label styleClass="headline-md" text="Lessons" />
                                <Label fx:id="lbLessonCount" styleClass="label-sigil" text="(0)" opacity="0.5" />
                            </HBox>
                            <VBox fx:id="lessonsContainer" spacing="15.0">
                                <!-- Lesson items will be injected here -->
                            </VBox>
                        </VBox>

                        <!-- Quizzes Column -->
                        <VBox spacing="30.0" prefWidth="450">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Label styleClass="headline-md" text="Trials &amp; Quizzes" />
                                <Label fx:id="lbQuizCount" styleClass="label-sigil" text="(0)" opacity="0.5" />
                            </HBox>
                            <VBox fx:id="quizzesContainer" spacing="15.0">
                                <!-- Quiz items will be injected here -->
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </VBox>
</AnchorPane>
