<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="550.0" prefWidth="650.0" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Tutorials.ManagementLeconController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleBack" styleClass="secondary-button" text="&lt; Back" />
                  <Label styleClass="headline" text="Management Leçon" />
                  <Pane HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleAddLecon" styleClass="glow-button" text="+ Add New" />
               </children>
            </HBox>
            <TextField fx:id="searchField" promptText="🔍  Rechercher par titre..." styleClass="search-field" />
            <TableView fx:id="leconTable" prefHeight="450.0" prefWidth="610.0" VBox.vgrow="ALWAYS" styleClass="table-view tuto-table">
              <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colTitre" prefWidth="250.0" text="Titre" />
                <TableColumn fx:id="colOrdre" prefWidth="100.0" text="Ordre" />
                <TableColumn fx:id="colActions" prefWidth="180.0" text="Actions" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
