<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="260.0" prefWidth="400.0" stylesheets="@../style.css" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Tutorials.EditJeuController">
    <children>
        <VBox alignment="CENTER" spacing="15" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            <Label styleClass="headline" text="Editer le Jeu" />
            <VBox spacing="15" styleClass="panel-card">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="form-label" text="Nom du jeu:" prefWidth="120" />
                    <TextField fx:id="tfNom" promptText="Entrer le nom" HBox.hgrow="ALWAYS" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="form-label" text="Genre:" prefWidth="120" />
                    <TextField fx:id="tfGenre" promptText="Entrer le genre" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>
            <Label fx:id="lbError" style="-fx-text-fill: #ff5555; -fx-font-weight: bold;" text="" />
            <HBox alignment="CENTER" spacing="10">
                <Button onAction="#sauvegarder" styleClass="glow-button" text="Enregistrer" />
                <Button onAction="#annuler" styleClass="secondary-button" text="Annuler" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>
