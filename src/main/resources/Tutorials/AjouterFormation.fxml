<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="450.0" prefWidth="450.0" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Tutorials.AjouterFormationController">
    <children>
        <VBox alignment="CENTER" spacing="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            <Label styleClass="headline" text="Ajouter une Formation" />
            
            <VBox spacing="15" styleClass="panel-card">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="120" styleClass="form-label" text="Titre :" />
                    <TextField fx:id="tfTitre" promptText="Entrez le titre" HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="120" styleClass="form-label" text="Description :" />
                    <TextField fx:id="tfDescription" promptText="Entrez la description" HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="120" styleClass="form-label" text="Niveau :" />
                    <ComboBox fx:id="cbNiveau" promptText="Sélectionnez le niveau" HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="120" styleClass="form-label" text="Jeu :" />
                    <ComboBox fx:id="cbJeu" promptText="Sélectionnez le jeu" HBox.hgrow="ALWAYS" />
                </HBox>
                
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="120" styleClass="form-label" text="URL de l'image :" />
                    <TextField fx:id="tfImage" promptText="Entrez l'URL de l'image" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="btnAjouter" onAction="#ajouterFormation" styleClass="glow-button" text="Ajouter" />
                <Button fx:id="btnAnnuler" onAction="#annuler" styleClass="secondary-button" text="Annuler" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>
