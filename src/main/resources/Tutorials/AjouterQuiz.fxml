<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="330.0" prefWidth="400.0" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Tutorials.AjouterQuizController">
    <children>
        <VBox alignment="CENTER" spacing="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            <Label styleClass="headline" text="Ajouter un Quiz" />
            
            <VBox spacing="15" styleClass="panel-card">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="120" styleClass="form-label" text="Titre :" />
                    <TextField fx:id="tfTitre" promptText="Entrez le titre" HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="120" styleClass="form-label" text="Ordre :" />
                    <TextField fx:id="tfOrdre" promptText="Ex: 1" HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="120" styleClass="form-label" text="Formation :" />
                    <ComboBox fx:id="cbFormation" promptText="Sélectionnez..." HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <Label fx:id="lbError" style="-fx-text-fill: #ff5555; -fx-font-weight: bold;" text="" />
            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="btnAjouter" onAction="#ajouterQuiz" styleClass="glow-button" text="Ajouter" />
                <Button fx:id="btnAnnuler" onAction="#annuler" styleClass="secondary-button" text="Annuler" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>
