<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="750.0" prefWidth="1000.0" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Tutorials.QuizResultController">
    <children>
        <VBox alignment="CENTER" spacing="40" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <padding>
                <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
            </padding>

            <VBox alignment="CENTER" spacing="30" maxWidth="600" styleClass="panel-card" style="-fx-background-color: #16161e; -fx-background-radius: 40; -fx-padding: 60;">
                
                <Label styleClass="headline-lg" text="TRIAL COMPLETE" style="-fx-text-fill: #a78bfa; -fx-letter-spacing: 5;" />
                
                <StackPane>
                    <Circle radius="80" fill="transparent" stroke="#6d28d9" strokeWidth="5" strokeDashArray="10" />
                    <VBox alignment="CENTER">
                        <Label fx:id="lbScore" text="7/10" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: white;" />
                        <Label text="SOULS REAPED" style="-fx-font-size: 12px; -fx-text-fill: #6d28d9; -fx-opacity: 0.8;" />
                    </VBox>
                </StackPane>

                <VBox alignment="CENTER" spacing="20" maxWidth="600">
                    <HBox alignment="CENTER" spacing="10">
                        <Label text="✧" style="-fx-text-fill: #a78bfa; -fx-font-size: 18px;" />
                        <Label text="THE ORACLE'S VERDICT" style="-fx-text-fill: #8b5cf6; -fx-font-size: 14px; -fx-font-weight: bold; -fx-letter-spacing: 1;" />
                        <Label text="✧" style="-fx-text-fill: #a78bfa; -fx-font-size: 18px;" />
                    </HBox>
                    <VBox style="-fx-background-color: rgba(13, 13, 18, 0.8); -fx-background-radius: 20; -fx-border-color: rgba(109, 40, 217, 0.5); -fx-border-radius: 20; -fx-border-width: 1.5; -fx-padding: 30 40;" alignment="CENTER" minHeight="180">
                        <Label fx:id="lbMessage" text="You have shown great potential, apprentice." wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #e2e8f0; -fx-font-size: 15px; -fx-line-spacing: 6; -fx-font-style: italic;" prefWidth="500" minHeight="-Infinity" />
                    </VBox>
                    <Label fx:id="lbPercent" text="70% Accuracy" style="-fx-text-fill: #a78bfa; -fx-font-weight: bold; -fx-font-size: 16px;" />
                </VBox>

                <HBox alignment="CENTER" spacing="20">
                    <Button onAction="#handleRestart" styleClass="ethereal-button" text="RETRY TRIAL" prefWidth="180" prefHeight="45" />
                    <Button onAction="#handleFinish" styleClass="glow-button" text="CLAIM REWARD" prefWidth="180" prefHeight="45" />
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
