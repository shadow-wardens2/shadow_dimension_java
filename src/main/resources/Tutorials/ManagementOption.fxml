<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="580.0" prefWidth="680.0" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Tutorials.ManagementOptionController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="24.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="16.0">
               <children>
                  <Label styleClass="headline" text="Management Option" />
                  <Pane HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleAddOption" styleClass="glow-button" text="+ Add New" />
               </children>
            </HBox>
            <TextField fx:id="searchField" promptText="🔍  Rechercher par texte..." styleClass="search-field" />
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane" hbarPolicy="NEVER">
               <content>
                  <VBox fx:id="listContainer" spacing="12" style="-fx-padding: 4 2 4 2;" />
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
