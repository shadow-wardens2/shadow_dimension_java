<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="560.0" prefWidth="980.0" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Tutorials.ManagementQuizDetailsController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <HBox alignment="CENTER_LEFT" spacing="16.0">
            <Button mnemonicParsing="false" onAction="#handleBack" styleClass="secondary-button" text="&lt; Back" />
            <Label fx:id="lbQuizTitle" styleClass="headline" text="Quiz Details" />
         </HBox>
         <HBox spacing="24.0" VBox.vgrow="ALWAYS">
            <!-- QUESTIONS PANEL -->
            <VBox spacing="12.0" HBox.hgrow="ALWAYS">
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <Label style="-fx-text-fill: #ba9eff; -fx-font-size: 16px; -fx-font-weight: bold;" text="Questions" />
                  <Pane HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnAddQuestion" mnemonicParsing="false" onAction="#handleAddQuestion" styleClass="glow-button" text="+ Question" />
               </HBox>
               <TextField fx:id="questionSearchField" promptText="🔍  Rechercher une question..." styleClass="search-field" />
               <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane" hbarPolicy="NEVER" prefHeight="360.0">
                  <VBox fx:id="questionContainer" spacing="10" style="-fx-padding: 2;" />
               </ScrollPane>
            </VBox>

            <!-- OPTIONS PANEL -->
            <VBox spacing="12.0" HBox.hgrow="ALWAYS">
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <Label style="-fx-text-fill: #ba9eff; -fx-font-size: 16px; -fx-font-weight: bold;" text="Options" />
                  <Pane HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnAddOption" mnemonicParsing="false" onAction="#handleAddOption" styleClass="glow-button" text="+ Option" />
               </HBox>
               <TextField fx:id="optionSearchField" promptText="🔍  Rechercher une option..." styleClass="search-field" />
               <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane" hbarPolicy="NEVER" prefHeight="360.0">
                  <VBox fx:id="optionContainer" spacing="10" style="-fx-padding: 2;" />
               </ScrollPane>
            </VBox>
         </HBox>
      </VBox>
   </children>
</AnchorPane>
