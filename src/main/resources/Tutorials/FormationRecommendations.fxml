<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: transparent;" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Tutorials.FormationRecommendationsController">
    <children>
        <VBox alignment="CENTER" spacing="25" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20" styleClass="panel-card" style="-fx-background-color: #0d0d12; -fx-background-radius: 40; -fx-border-color: #6d28d9; -fx-border-radius: 40; -fx-border-width: 2;">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <Label text="THE AI ORACLE" styleClass="label-sigil" style="-fx-text-fill: #a78bfa; -fx-font-size: 14px;" />
            
            <StackPane>
                <VBox fx:id="vbLoading" alignment="CENTER" spacing="20">
                    <ProgressIndicator prefHeight="80" prefWidth="80" styleClass="ethereal-progress" />
                    <Label text="Consulting the shadows..." style="-fx-text-fill: #666; -fx-font-family: 'Inter';" />
                </VBox>
                
                <VBox fx:id="vbResult" alignment="CENTER" spacing="20" visible="false">
                    <Label fx:id="lbRecommendationTitle" text="Formation Title" wrapText="true" textAlignment="CENTER" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                    <Label fx:id="lbReasoning" text="The Oracle sees great potential in your soul..." wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #aaa; -fx-font-size: 16px; -fx-line-spacing: 5;" />
                    
                    <Region prefHeight="10" />
                    <Button onAction="#handleClose" styleClass="glow-button" text="I ACCEPT THIS DESTINY" prefWidth="250" />
                </VBox>
            </StackPane>
        </VBox>
    </children>
</AnchorPane>
