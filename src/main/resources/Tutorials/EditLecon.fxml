<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="550.0" prefWidth="550.0" stylesheets="@../style.css" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Tutorials.EditLeconController">
    <children>
        <VBox alignment="CENTER" spacing="15" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            <Label styleClass="headline" text="Editer la Leçon" />
            <VBox spacing="10" styleClass="panel-card">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="form-label" text="Titre:" prefWidth="120" />
                    <TextField fx:id="tfTitre" promptText="Entrer le titre" HBox.hgrow="ALWAYS" />
                </HBox>
                <HBox alignment="TOP_LEFT" spacing="10">
                    <Label styleClass="form-label" text="Contenu:" prefWidth="120" />
                    <TextArea fx:id="taContenu" prefHeight="60.0" promptText="Entrer le contenu..." HBox.hgrow="ALWAYS" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="form-label" text="Ordre:" prefWidth="120" />
                    <TextField fx:id="tfOrdre" promptText="Ex: 1" HBox.hgrow="ALWAYS" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="form-label" text="URL Image:" prefWidth="120" />
                    <TextField fx:id="tfImage" promptText="URL image" HBox.hgrow="ALWAYS" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="form-label" text="URL Video:" prefWidth="120" />
                    <TextField fx:id="tfVideoUrl" promptText="URL video" HBox.hgrow="ALWAYS" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="form-label" text="Durée vidéo:" prefWidth="120" />
                    <TextField fx:id="tfVideoDuration" promptText="Ex: 12:45" HBox.hgrow="ALWAYS" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="form-label" text="Document URL:" prefWidth="120" />
                    <TextField fx:id="tfDocumentUrl" promptText="Lien doc" HBox.hgrow="ALWAYS" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="form-label" text="Miniature Video:" prefWidth="120" />
                    <TextField fx:id="tfVideoThumbnail" promptText="URL de la miniature" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>
            <HBox alignment="CENTER" spacing="10">
                <Button onAction="#sauvegarder" styleClass="glow-button" text="Enregistrer" />
                <Button onAction="#annuler" styleClass="secondary-button" text="Annuler" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>
